# Copy to .env.local for local dev, and set the same vars in your Vercel
# project (Settings → Environment Variables) for production.
# .env.local is gitignored — never commit real secrets.

# Resend API key — required for the contact/waitlist forms to send.
# Get it from https://resend.com/api-keys (server-only; do NOT prefix NEXT_PUBLIC_).
RESEND_API_KEY=

# Optional — inbox that receives lead notifications.
# Defaults to technotonin@gmail.com if unset.
LEADS_TO_EMAIL=

# Optional — verified sender. Until you verify a domain in Resend, leave this
# unset (defaults to onboarding@resend.dev). After verifying
# wheelchairattachment.com, set e.g. "PAWE <leads@wheelchairattachment.com>".
RESEND_FROM=

# Optional — canonical site URL (also used for SEO). Defaults to the production
# domain in lib/seo.ts. Set this to the EXACT host you serve (incl. www if your
# domain redirects to www) so canonicals/sitemap match the live URLs.
NEXT_PUBLIC_SITE_URL=

# Optional — Google Search Console HTML-tag verification token. Set this to the
# value Google gives you (Search Console → add property → HTML tag) and redeploy
# to verify ownership. Not needed if you verify via DNS instead.
GOOGLE_SITE_VERIFICATION=
